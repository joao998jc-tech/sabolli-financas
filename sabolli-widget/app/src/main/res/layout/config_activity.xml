<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:text="$"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/widget_bg"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Configurar Widget Sabolli"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1E3A8A"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Para sincronizar seu saldo, cole o Código do Widget.\n\nEncontre-o no app → menu lateral → Temas do App → seção Widget."
        android:textSize="14sp"
        android:textColor="#555555"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <EditText
        android:id="@+id/et_code"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Cole o Código do Widget aqui"
        android:textSize="14sp"
        android:padding="14dp"
        android:background="@android:drawable/edit_text"
        android:inputType="textNoSuggestions"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tv_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#DC2626"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_confirm"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Adicionar Widget"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:background="@drawable/widget_bg" />

</LinearLayout>
